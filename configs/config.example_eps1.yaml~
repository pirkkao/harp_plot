#
# ENSEMBLE PLOTTING EXAMPLE 1:
# the basics
#
# Load in 1 data source, but multiple ensemble member.
# Illustrates how to plot ensemble stats.
#
data:
  1:
    tmpl: local_fa_pl
    exp:  ["cy46_uwc_def"]
    ensm: [0,1,2]
    flds: ["CLSTEMPERATURE"]

times:
  sdate: 2025012112
  lead_times: 12

grid:
  subgrid:
  regrid:

opts:
  fig_name: "fig/example_eps1.png"
  fig_size: [12,4,300] # [width,heigh,dpi]
  collect_guides: false

# plot:
#   row1:
#     column1:
#       ...
#     column2:
#       ...
#   row2:
#     column1:
#       ...
#     column2:
#       ...
plot:
  1:
    1:
      type: "fc"
      data1: 1
      ensm: [0]
      name: "ctrl"
      col_map: 1
    2: 
      type: "ens_mean"
      data1: 1
      ensm:
      name: "ensm"
      col_map: 1
    3: 
      type: "ens_sd"
      data1: 1
      ensm: [0]
      name: "sdev"
      col_map: 2

col_maps:
  1:
    name: 'scale_fill_stepsn(colours=scico(54,palette="oslo",direction=1,begin=0),limits=c(-20,0),breaks=c(-20,-15,-10,0))'
    legend: "t2m"
  2:
    name: "sdev"
    legend: "sdev"
